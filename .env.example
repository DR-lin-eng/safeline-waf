# SafeLine WAF 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ============ Redis 配置 ============
REDIS_PASSWORD=safeline-redis-secret

# ============ 认证配置 ============
# JWT密钥 - 生产环境必须使用强密钥（至少32字符，包含大小写字母、数字、特殊字符）
JWT_SECRET=change-this-jwt-secret-in-production-use-strong-random-string

# 管理员用户名
ADMIN_USERNAME=admin

# 管理员密码哈希
# 生成方法: node -e "require('bcryptjs').hash('你的密码',12).then(console.log)"
# 默认密码: SafeLine@2024
ADMIN_PASSWORD_HASH=$2a$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/LnITHEhV1xnSqxSyu

# ============ 集群配置 ============
# 是否启用集群功能 (true/false)
CLUSTER_ENABLED=true

# 节点唯一标识 (每个节点必须不同)
# 示例: node-1, node-2, waf-beijing-01, waf-shanghai-01
NODE_ID=node-1

# 节点角色 (worker/primary)
# worker: 工作节点，从Redis获取配置
# primary: 主节点（保留，暂未使用）
NODE_ROLE=worker

# 心跳间隔（秒）
HEARTBEAT_INTERVAL=30

# ============ 其他配置 ============
# 运行环境
NODE_ENV=production

# 前端URL（用于CORS配置）
FRONTEND_URL=http://localhost:8080

# ============ 多节点部署示例 ============
# 节点1 (.env):
# NODE_ID=node-1
# CLUSTER_ENABLED=true
#
# 节点2 (.env):
# NODE_ID=node-2
# CLUSTER_ENABLED=true
#
# 注意：所有节点必须连接到同一个Redis实例
