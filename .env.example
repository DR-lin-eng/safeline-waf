# SafeLine WAF 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ============ Redis 配置 ============
REDIS_PASSWORD=safeline-redis-secret

# ============ 认证配置 ============
# JWT密钥 - 生产环境必须使用强密钥（至少32字符，包含大小写字母、数字、特殊字符）
JWT_SECRET=change-this-jwt-secret-in-production-use-strong-random-string

# 管理员用户名
ADMIN_USERNAME=admin

# 管理员密码哈希
# 生成方法: node -e "require('bcryptjs').hash('你的密码',12).then(console.log)"
# 写入 .env 时请将 bcrypt 哈希中的 $ 转义为 $$，避免被 docker compose 插值
ADMIN_PASSWORD_HASH=$$2a$$12$$replace.with.your.own.generated.hash.value

# ============ 在线更新配置 ============
# 在线更新服务与管理后端之间的共享鉴权令牌，建议使用 openssl rand -hex 32 生成
UPDATER_SHARED_TOKEN=change-this-updater-token-in-production

# 服务器上的项目绝对路径。在线更新会使用它来执行 docker compose 和 git pull
UPDATER_WORKSPACE_DIR=/opt/safeline-waf

# ============ 集群配置 ============
# 是否启用集群功能 (true/false)
CLUSTER_ENABLED=false

# 节点唯一标识 (每个节点必须不同)
# 示例: node-1, node-2, waf-beijing-01, waf-shanghai-01
NODE_ID=node-1

# 节点角色 (primary/secondary)
# primary: 主节点，维护统一配置并触发下发
# secondary: 从节点，接收主节点配置并同步状态
NODE_ROLE=secondary

# 心跳间隔（秒）
HEARTBEAT_INTERVAL=30

# ============ 其他配置 ============
# 运行环境
NODE_ENV=production

# 生产镜像更新通道
SAFELINE_TAG=main

# 前端URL（用于CORS配置）
FRONTEND_URL=http://localhost:8080

# ============ 在线更新配置（可选） ============
# 若不单独设置，在线更新服务会回退使用 JWT_SECRET 进行内部鉴权
# UPDATER_SHARED_SECRET=change-this-updater-secret

# 在线更新默认拉取的 Git 远端/分支
UPDATER_GIT_REMOTE=origin
UPDATER_GIT_BRANCH=main

# ============ 多节点部署示例 ============
# 节点1 (.env):
# NODE_ID=node-1
# CLUSTER_ENABLED=true
#
# 节点2 (.env):
# NODE_ID=node-2
# CLUSTER_ENABLED=true
#
# 注意：所有节点必须连接到同一个Redis实例
